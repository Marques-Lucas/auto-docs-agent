# Copie este arquivo para ".env" e coloque sua chave de verdade.
# Pegue uma API key gratis da Groq em: https://console.groq.com/keys

GROQ_API_KEY=coloque_sua_chave_aqui

# Modelo da Groq que vamos usar (pode trocar depois).
# Lista de modelos: https://console.groq.com/docs/models
GROQ_MODEL=llama-3.3-70b-versatile
